# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# --- Virtual environment ---
venv/
env/
.venv/

# --- Database (contains real user data & password hashes) ---
*.db
*.sqlite
*.sqlite3

# --- Secrets / environment ---
.env
.flaskenv
*.pem
*.key

# --- User-uploaded content (runtime data, not source) ---
static/uploads/*
!static/uploads/.gitkeep

# --- OS / editor junk ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Generated reports / scratch files ---
_gen_*.py
